{
  "manifest_version": 3,
  "name": "Cryptool",
  "version": "1.2.0",
  "description": "AES-256 encrypted memo viewer.",
  "icons": {
    "128": "images/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "images/icon.png"
    }
  },
  "options_ui": {
    "page": "viewer.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [],
  "host_permissions": []
}
