{
  "manifest_version": 3,
  "name": "Cryptool",
  "version": "1.1.0",
  "description": "AES-256 encrypted memo viewer.",
  "icons": {
    "128": "images/icon.png"
  },
  "action": {
    "default_icon": {
      "128": "images/icon.png"
    }
  },
  "options_ui": {
    "page": "viewer.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": []
}
